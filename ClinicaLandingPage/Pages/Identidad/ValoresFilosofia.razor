
<MudGrid Class="mt-8">
    <MudItem xs="12">
        <MudText Typo="Typo.h4" Align="Align.Center" Class="mb-6">Nuestros Valores y Filosofía</MudText>
    </MudItem>
    
    <MudItem xs="12" md="4">
        <MudCard Elevation="2" Class="height-full">
            <MudCardContent>
                <MudIcon Icon="@Icons.Material.Filled.Favorite" Color="Color.Error" Size="Size.Large" />
                <MudText Typo="Typo.h6">Ética y Humanismo</MudText>
                <MudText Typo="Typo.body2">Nuestra filosofía se basa en tratar a cada paciente como a un miembro de nuestra familia.</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" md="4">
        <MudCard Elevation="2">
            <MudCardContent>
                <MudIcon Icon="@Icons.Material.Filled.VerifiedUser" Color="Color.Success" Size="Size.Large" />
                <MudText Typo="Typo.h6">Integridad</MudText>
                <MudText Typo="Typo.body2">Transparencia total en nuestros procesos médicos y administrativos.</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" md="4">
        <MudCard Elevation="2">
            <MudCardContent>
                <MudIcon Icon="@Icons.Material.Filled.Public" Color="Color.Info" Size="Size.Large" />
                <MudText Typo="Typo.h6">Aporte al País</MudText>
                <MudText Typo="Typo.body2">Contribuimos al desarrollo nacional mejorando los estándares de salud pública en Perú.</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>