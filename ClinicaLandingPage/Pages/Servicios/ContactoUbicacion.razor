@using MudBlazor

<section id="contacto" class="mt-12 mb-16" style="scroll-margin-top: 90px;">
    <MudText Typo="Typo.h4" Align="Align.Center" Class="mb-8">Contacto y Ubicación</MudText>

    <MudGrid>
        <MudItem xs="12" md="5">
            <MudPaper Elevation="2" Class="pa-6 rounded-lg h-100">
                <MudText Typo="Typo.h6" Color="Color.Primary" Class="mb-4">Información de Atención</MudText>
                
                <MudList T="string">
                    <MudListItem Icon="@Icons.Material.Filled.Place">
                        <MudText Typo="Typo.body1"><strong>Dirección:</strong> Av. Principal 123, Juliaca, Perú</MudText>
                    </MudListItem>
                    <MudListItem Icon="@Icons.Material.Filled.Phone">
                        <MudText Typo="Typo.body1"><strong>Teléfono:</strong> +51 987 654 321</MudText>
                    </MudListItem>
                    <MudListItem Icon="@Icons.Material.Filled.Email">
                        <MudText Typo="Typo.body1"><strong>Email:</strong> contacto@tuclinica.com</MudText>
                    </MudListItem>
                    <MudListItem Icon="@Icons.Material.Filled.AccessTime">
                        <MudText Typo="Typo.body1"><strong>Horario:</strong> Lun - Sáb: 8:00 AM - 8:00 PM</MudText>
                    </MudListItem>
                </MudList>

                <MudDivider Class="my-4" />

                <MudText Typo="Typo.subtitle1" Class="mb-2 fw-bold">¿Necesitas ayuda rápida?</MudText>
                @* Botón de WhatsApp - Preparado para tu backend *@
                <MudButton Variant="Variant.Filled" 
                           Color="Color.Success" 
                           FullWidth="true" 
                           Size="Size.Large"
                           StartIcon="@Icons.Custom.Brands.WhatsApp"
                           Href="https://wa.me/51987654321" 
                           Target="_blank">
                    Escríbenos por WhatsApp
                </MudButton>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="7">
            <MudPaper Elevation="2" Class="rounded-lg overflow-hidden h-100" Style="min-height: 400px;">
                @* Reemplaza este src con el link de "Insertar mapa" de Google Maps de la ubicación real *@
                <iframe 
                    src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d15344.604646733262!2d-70.133261!3d-15.492045!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x9167f3944111394f%3A0xc66c1e55047b744d!2sJuliaca!5e0!3m2!1ses!2spe!4v1713000000000!5m2!1ses!2spe" 
                    width="100%" 
                    height="100%" 
                    style="border:0; min-height: 400px;" 
                    allowfullscreen="" 
                    loading="lazy">
                </iframe>
            </MudPaper>
        </MudItem>
    </MudGrid>
</section>
