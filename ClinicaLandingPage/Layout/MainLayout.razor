@inherits LayoutComponentBase

<MudThemeProvider Theme="@_miTemaCustom" @bind-IsDarkMode="_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Color="Color.Surface" Fixed="true" Elevation="2" Class="px-4">
        @* Botón de Menú para el Drawer *@
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Primary" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />
        
        @* Identidad de la Clínica *@
        <img src="/images/logo.png" alt="Logo Santa Mónica" style="height:105px; width:auto; object-fit:contain;" class="ml-3 mr-2 py-1" />
        <MudText Typo="Typo.h6" Color="Color.Primary" Class="fw-bold d-none d-sm-inline">
            Clínica Santa Mónica
        </MudText>
        
        <MudSpacer />
        
        @* Switch de Modo Oscuro con Tooltip para UX *@
        <MudTooltip Text="@(_isDarkMode ? "Cambiar a Modo Claro" : "Cambiar a Modo Oscuro")">
            <MudIconButton 
                Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)" 
                Color="Color.Inherit" 
                OnClick="@(() => _isDarkMode = !_isDarkMode)" 
                Class="mr-2" />
        </MudTooltip>

        @* Botón de Acceso al Sistema SIGEC *@
        <MudButton Variant="Variant.Filled" 
                   Color="Color.Primary" 
                   Size="Size.Medium"
                   EndIcon="@Icons.Material.Filled.Login" 
                   Class="rounded-pill px-6 d-none d-sm-flex">
            Portal SIGEC
        </MudButton>
        
        @* Icono de acceso para móviles *@
        <MudIconButton Icon="@Icons.Material.Filled.Login" Color="Color.Primary" Class="d-flex d-sm-none" />
    </MudAppBar>

    @* Drawer Lateral con el NavMenu *@
    <MudDrawer @bind-Open="_drawerOpen" Elevation="4" ClipMode="DrawerClipMode.Always" Variant="@DrawerVariant.Responsive">
        <MudDrawerHeader Class="pa-4">
            <MudText Typo="Typo.subtitle1" Color="Color.Primary" Class="fw-bold">Clínica Santa Monica</MudText>
        </MudDrawerHeader>
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        @* El contenedor principal donde se renderiza el Home.razor *@
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    bool _drawerOpen = true;
    bool _isDarkMode; 
    
    private ClinicaTheme _miTemaCustom = new();

    void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }

    protected override void OnInitialized()
    {
        // El modo oscuro se vincula automáticamente con MudThemeProvider.
        // Aquí podrías agregar lógica para persistir la preferencia en LocalStorage en el futuro.
    }
}