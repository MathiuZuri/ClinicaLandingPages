@using MudBlazor

<MudText Typo="Typo.h4" Align="Align.Center" Color="Color.Primary" Class="mb-8 fw-bold">Estructura Organizacional y Roles SIGEC</MudText>

<MudGrid>
    <MudItem xs="12" md="5">
        <MudPaper Elevation="4" Class="pa-6 rounded-lg border-l-4" Style="border-left-color: var(--mud-palette-primary); height: 100%;">
            <MudText Typo="Typo.h6" Class="mb-4">
                <MudIcon Icon="@Icons.Material.Filled.AccountTree" Class="mr-2" />
                Organigrama Institucional
            </MudText>
            <MudTreeView T="string" Hover="true">
                <MudTreeViewItem Value="@("GERENCIA GENERAL (Dueña / Directora)")" Expanded="true">
                    
                    <MudTreeViewItem Value="@("ADMISIÓN Y CAJA (Citas y Cobros)")" Expanded="true">
                        <MudTreeViewItem Value="@("SERVICIOS EXT. (Farmacia / Laboratorio)")" />
                    </MudTreeViewItem>

                    <MudTreeViewItem Value="@("DIRECCIÓN MÉDICA")" Expanded="true">
                        <MudTreeViewItem Value="@("CONSULTA (Triaje / Eco / Controles)")" />
                        <MudTreeViewItem Value="@("HOSPITAL (Camas / Post-parto)")" />
                        <MudTreeViewItem Value="@("CENTRO QUIRÚRGICO (Partos / Cesáreas)")" />
                    </MudTreeViewItem>

                </MudTreeViewItem>
            </MudTreeView>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="7">
        <MudExpansionPanels MultiExpansion="true" Elevation="2" Class="rounded-lg overflow-hidden">
            <MudExpansionPanel Text="Área de Gerencia y Dirección (Acceso Total)">
                <MudText Typo="Typo.body2">
                    Supervisión global de la clínica. El sistema <strong>SIGEC</strong> otorga a este rol acceso a reportes gerenciales, estadísticas de cirugías y visualización de ecografías de alta complejidad.
                </MudText>
            </MudExpansionPanel>
            <MudExpansionPanel Text="Área Médica y Obstétrica (Gestión Clínica)">
                <MudText Typo="Typo.body2">
                    Responsables de la evolución de la paciente. Tienen permisos para edición de <strong>Historias Clínicas</strong>, registro de triaje y seguimiento de controles prenatales.
                </MudText>
            </MudExpansionPanel>
            <MudExpansionPanel Text="Admisión, Caja y Hospitalización">
                <MudText Typo="Typo.body2">
                    Gestión de flujo de pacientes. Incluye el control de citas, cobros y, en el área de hospitalización, el registro estricto de administración de medicamentos mediante el módulo de enfermería.
                </MudText>
            </MudExpansionPanel>
        </MudExpansionPanels>
        
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-4" Icon="@Icons.Material.Filled.Lock">
            Los roles de usuario en SIGEC están segmentados por arquitectura de seguridad para garantizar la protección de datos sensibles.
        </MudAlert>
    </MudItem>

    <MudItem xs="12">
        <MudText Typo="Typo.h5" Align="Align.Center" Color="Color.Primary" Class="mt-10 mb-6 fw-bold">Personal y Roles de Sistema</MudText>
        <MudGrid>
            @foreach (var persona in _staff)
            {
                <MudItem xs="12" sm="6" md="3">
                    <MudCard Elevation="3" Class="h-100 rounded-lg border-t-4" Style="@($"border-top-color: {persona.ColorBorde};")">
                        <MudCardHeader>
                            <CardHeaderAvatar>
                                <MudAvatar Color="persona.AvatarColor" Variant="Variant.Filled">@persona.Nombre[0]</MudAvatar>
                            </CardHeaderAvatar>
                            <CardHeaderContent>
                                <MudText Typo="Typo.subtitle1" Class="fw-bold">@persona.Nombre</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@persona.Cargo</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudText Typo="Typo.body2" Class="text-muted"><strong>Permisos:</strong> @persona.Descripcion</MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    </MudItem>
</MudGrid>

@code {
    private List<StaffMember> _staff = new()
    {
        new StaffMember { 
            Nombre = "Dra. Dueña/Directora", 
            Cargo = "Gerente General", 
            Descripcion = "Acceso total a reportes, ecografías, programación quirúrgica y auditoría de SIGEC.",
            AvatarColor = Color.Dark,
            ColorBorde = "var(--mud-palette-dark)"
        },
        new StaffMember { 
            Nombre = "Obstetra de Turno", 
            Cargo = "Especialista Obstetra", 
            Descripcion = "Gestión de Historia Clínica, registro de triaje y control prenatal de pacientes.",
            AvatarColor = Color.Primary,
            ColorBorde = "var(--mud-palette-primary)"
        },
        new StaffMember { 
            Nombre = "Personal de Admisión", 
            Cargo = "Recepcionista", 
            Descripcion = "Módulo de agendamiento de citas, registro de DNI y gestión de cobros en caja.",
            AvatarColor = Color.Info,
            ColorBorde = "var(--mud-palette-info)"
        },
        new StaffMember { 
            Nombre = "Lic. en Enfermería", 
            Cargo = "Hospitalización", 
            Descripcion = "Registro de administración de medicamentos y monitoreo post-parto en sistema.",
            AvatarColor = Color.Success,
            ColorBorde = "var(--mud-palette-success)"
        }
    };

    public class StaffMember {
        public string Nombre { get; set; } = string.Empty;
        public string Cargo { get; set; } = string.Empty;
        public string Descripcion { get; set; } = string.Empty;
        public Color AvatarColor { get; set; }
        public string ColorBorde { get; set; } = "transparent";
    }
}